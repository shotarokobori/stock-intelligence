# Anthropic / Claude
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを貼り付けてください
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_MAX_TOKENS=8000

# YouTube Data API
YOUTUBE_API_KEY=ここにYouTube Data APIキーを貼り付けてください
YOUTUBE_MAX_RESULTS_PER_CHANNEL=3
YOUTUBE_PUBLISHED_WITHIN_HOURS=24

# Gmail
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_SENDER_PASSWORD=ここにアプリパスワードを貼り付けてください
GMAIL_RECIPIENT_EMAILS=your-email@gmail.com,other-email@example.com

# システム設定
SYSTEM_MAX_ARTICLES_PER_SOURCE=5
SYSTEM_ARTICLE_PREVIEW_CHARS=300
SYSTEM_YOUTUBE_TRANSCRIPT_CHARS=3000
SYSTEM_LOG_FILE=logs/system.log
SYSTEM_DATA_DIR=data
SYSTEM_TEST_MODE=false

# レポート設定
REPORT_SEND_HOUR=7
REPORT_SEND_MINUTE=0
REPORT_LANGUAGE=日本語
REPORT_INVESTMENT_FOCUS=日本株
